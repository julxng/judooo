{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "npx tsc --noEmit --pretty 2>&1 | head -20" }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "if echo \"$TOOL_INPUT\" | grep -qE '\\.env(\\..*)?$'; then echo 'BLOCK: Do not edit .env files'; exit 1; fi" }]
      }
    ]
  }
}
