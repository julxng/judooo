SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Comma-separated RSS/Atom URLs
CRAWL_SOURCE_URLS=https://hanoigrapevine.com/feed/

# Optional Google News expansion (comma-separated queries)
CRAWL_GOOGLE_NEWS_QUERIES=Vietnam art exhibition,Hanoi gallery opening,Saigon contemporary art
CRAWL_GOOGLE_NEWS_HL=en-US
CRAWL_GOOGLE_NEWS_GL=US
CRAWL_GOOGLE_NEWS_CEID=US:en

# Optional Facebook Group ingest (requires Graph API access token + permissions)
CRAWL_FACEBOOK_GROUP_IDS=
FACEBOOK_GRAPH_ACCESS_TOKEN=
CRAWL_FACEBOOK_LIMIT=25

# Optional defaults
CRAWL_DEFAULT_LOCATION=Vietnam
CRAWL_DEFAULT_CATEGORY=exhibition
CRAWL_BATCH_LIMIT=30

# Artwork import (Wikidata/Wikipedia)
CRAWL_ARTWORK_LIMIT=0
CRAWL_ARTWORK_PRICE_MIN=6000000
CRAWL_ARTWORK_PRICE_MAX=30000000
CRAWL_WIKIDATA_RETRIES=4
CRAWL_NGUYEN_COLLECTION_URL=https://nguyenartfoundation.com/vn/collection/suu-tap/
CRAWL_NGUYEN_MAX_PAGES=120

# Optional no-key web search fallback queries (DuckDuckGo)
CRAWL_WEB_ARTWORK_QUERIES=Vietnamese painting,Vietnamese artwork,Vietnam contemporary art
