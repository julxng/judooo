{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "baseUrl": ".",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "vite/client"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": false,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["src/*"],
      "@app/*": ["src/app/*"],
      "@assets/*": ["src/assets/*"],
      "@components/*": ["src/components/*"],
      "@design-system/*": ["src/design-system/*"],
      "@features/*": ["src/features/*"],
      "@hooks/*": ["src/hooks/*"],
      "@lib/*": ["src/lib/*"],
      "@services/*": ["src/services/*"],
      "@styles/*": ["src/styles/*"],
      "@types": ["src/types/index.ts"],
      "@types/*": ["src/types/*"],
      "@ui/*": ["src/components/ui/*"],
      "@utils/*": ["src/utils/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "index.tsx",
    "App.tsx",
    "constants.tsx",
    "translations.ts",
    "types.ts",
    "services/**/*.ts",
    "components/**/*.tsx",
    "vite.config.ts"
  ],
  "exclude": [
    "dist",
    "docs",
    "logs",
    "node_modules",
    "scripts",
    "supabase"
  ]
}
