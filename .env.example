NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional (used by Gemini service if enabled)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# App URL (used for payment return URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# VNPay — https://sandbox.vnpayment.vn/devreg/
VNPAY_TMN_CODE=YOUR_TMN_CODE
VNPAY_HASH_SECRET=YOUR_HASH_SECRET
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Production: VNPAY_URL=https://pay.vnpay.vn/vpcpay.html

# MoMo — https://developers.momo.vn/
MOMO_PARTNER_CODE=YOUR_PARTNER_CODE
MOMO_ACCESS_KEY=YOUR_ACCESS_KEY
MOMO_SECRET_KEY=YOUR_SECRET_KEY
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
# Production: MOMO_ENDPOINT=https://payment.momo.vn/v2/gateway/api/create

# Bank Transfer — your business bank account
BANK_NAME=MB Bank
BANK_ACCOUNT_NUMBER=0000000000000
BANK_ACCOUNT_NAME=CONG TY JUDOOO
BANK_BRANCH=Chi nhanh Ha Noi
